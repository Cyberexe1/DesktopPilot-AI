# Copy this to .env — never commit .env

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

S3_BUCKET_NAME=desktoppilot-audio

DYNAMODB_TABLE_MEMORY=DesktopPilotMemory
DYNAMODB_TABLE_COMMANDS=DesktopPilotCommands


BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0

# Optional: Use a separate model for prompt enhancement (defaults to BEDROCK_MODEL_ID)
# Nova Lite is fast and cheap — perfect for simple prompt rewrites
BEDROCK_ENHANCER_MODEL_ID=us.amazon.nova-lite-v1:0

STEP_FUNCTION_ARN=arn:aws:states:us-east-1:ACCOUNT_ID:stateMachine:DesktopPilotWorkflow

# Wake word listener (openwakeword — free, no API key needed)
# Options: hey_jarvis | alexa | hey_mycroft | path/to/custom_model.tflite
WAKE_WORD_MODEL=hey_jarvis

# Detection sensitivity 0.0 (loose) to 1.0 (strict) — 0.5 recommended
WAKE_WORD_THRESHOLD=0.5

# Whisper model size: tiny | base | small | medium | disabled
WHISPER_MODEL=medium
